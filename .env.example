# Managed by ShtetlFrames UI / Settings panel.

# local | runpod  (runpod auto-creates a GPU Pod — no endpoint ID, no local Docker required)
SCAN_BACKEND=runpod

# From https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=rpa_replace_me

# Optional image override. Leave empty to use built-in CUDA 12.4 RunPod PyTorch candidates.
RUNPOD_DOCKER_IMAGE=

# RunPod gpuTypeId
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 3090

# Scrape GPU pods (1–8). Pathé may add +1 discover pod (hard account cap 9).
RUNPOD_MAX_INFLIGHT=8

# Parallel Pathé discover page fetches (1–6; higher fills the scrape queue faster).
PATHE_DISCOVER_CONCURRENCY=4

# Max concurrent Pathé scans per GPU (1–6). Same key as Settings → Pathé jobs per GPU.
PATHE_STACK_MAX=3

RUNPOD_JOB_TIMEOUT_SEC=1800

# 1 = stop the GPU pod after scrape finishes
RUNPOD_STOP_WHEN_DONE=1

# Soft CLIP gate before vision verify (raise to cut false positives)
SCORE_THRESHOLD=0.04

# Second pass: vision model re-checks every CLIP-flagged still (optional)
# 1 = on when the selected backend is configured; 0 = CLIP only
OPENAI_VERIFY=1
# openai | ollama_then_openai | open_vlm
VERIFY_BACKEND=openai
OPENAI_API_KEY=
# Optional model override (default gpt-5.4-mini)
OPENAI_MODEL=gpt-5.4-mini
# Ollama / open VLM (OpenAI-compatible). Cascade: Ollama first; OpenAI only on keeps.
OPEN_VLM_BASE_URL=pod
OPEN_VLM_MODEL=qwen2.5vl:3b
OPEN_VLM_API_KEY=

# YouTube proxy on the GPU (after bot-checks)
# auto | scrapfly | scrapingdog | none  (auto = Scrapfly, then ScrapingDog)
PROXY_PROVIDER=auto

# Scrapfly — https://scrapfly.io/dashboard
# - YouTube: proxy mode after bot-checks
# - British Pathé: ASP scrape of asset HTML only (then free fe-cdn HLS, no YT proxy)
SCRAPFLY_API_KEY=
# Optional: SCRAPFLY_COUNTRY=us

# ScrapingDog fallback — https://www.scrapingdog.com/dashboard
SCRAPINGDOG_API_KEY=
# Optional: SCRAPINGDOG_PROXY_URL=http://scrapingdog:KEY@proxy.scrapingdog.com:8081

# Sparse section helpers (unused by scrape — full video is always downloaded).
# Kept for scripts/tests that call sparse_download directly.
# SPARSE_SECTION_SEC=20
# SPARSE_STRIDE_SEC=60
# DENSE_PAD_SEC=30
# MAX_DENSE_SEC=600
